# Local development environment variables.
# For Streamlit Cloud, add the same keys in the app Secrets panel instead.
# Multiple keys can be provided as comma-separated lists.

# YouTube Data API
YOUTUBE_API_KEYS=your_youtube_key_1,your_youtube_key_2

# AI generation APIs
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2
OPENAI_API_KEYS=your_openai_key_1,your_openai_key_2

# Optional single-key fallbacks
# YOUTUBE_API_KEY=your_youtube_key
# GEMINI_API_KEY=your_gemini_key
# OPENAI_API_KEY=your_openai_key
