# GCP deployment environment template for YouTube IP V6.
# Use this as a source-of-truth template for Cloud Run, GCE, or a containerized deploy.
# Do NOT commit a real `.env` with secrets.
#
# Important:
# - The app reads environment variables directly in production.
# - It does not automatically call `load_dotenv()` at app boot.
# - On GCP, inject these values into the service/container environment.
# - This file is best used as a local template before copying values into Secret Manager
#   or your GCP service configuration.

# ------------------------------
# Core API providers
# ------------------------------

# Preferred pooled-key format
YOUTUBE_API_KEYS=your_youtube_key_1,your_youtube_key_2
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2
OPENAI_API_KEYS=your_openai_key_1,your_openai_key_2

# Optional single-key fallbacks
# YOUTUBE_API_KEY=your_youtube_key
# GEMINI_API_KEY=your_gemini_key
# OPENAI_API_KEY=your_openai_key

# ------------------------------
# Optional BERTopic beta settings
# ------------------------------

# Set to true only if you want the optional model-backed topic flow in Channel Insights.
MODEL_ARTIFACTS_ENABLED=true

# Public manifest URL for the BERTopic beta bundle.
MODEL_ARTIFACTS_MANIFEST_URL=https://raw.githubusercontent.com/royayushkr/Youtube-IP-V6/main/data/model_manifests/bertopic_manifest_2026.03.27.json

# Optional runtime overrides
MODEL_ARTIFACTS_CACHE_DIR=outputs/models/runtime
MODEL_ARTIFACTS_DOWNLOAD_TIMEOUT_SECONDS=300
MODEL_ARTIFACTS_MAX_SIZE_MB=512

# ------------------------------
# Notes
# ------------------------------
#
# 1. For Cloud Run, prefer Secret Manager or service-level environment variables.
# 2. For local container testing, you can source this file before launching Streamlit:
#      set -a
#      source .env.gcp
#      set +a
#      streamlit run streamlit_app.py
# 3. If you do not want BERTopic beta, remove the MODEL_ARTIFACTS_* values or set:
#      MODEL_ARTIFACTS_ENABLED=false
